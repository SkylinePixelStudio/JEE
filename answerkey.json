    /* Answer Key */
    .answer-key {
      background: #263238;
      color: white;
      border-radius: var(--radius);
      padding: 28px;
      overflow-x: auto;
    }

    .answer-key pre {
      font-family: 'Fira Code', monospace;
      font-size: 0.85rem;
      line-height: 1.65;
      color: #aed581;
      white-space: pre-wrap;
      word-wrap: break-word;
    }
